"DETERMINERS"

the  	  D *  (^ DEF) = +.

a   	  D *  (^ DEF) = -.


"ADJECTIVES"

small    A * @(AP small).

black    A * @(AP black).

hungry   A * @(AP hungry).



"ADVERBS"
very      Adv * @(Adv very).

quickly   Adv * @(Adv quickly).


"PRONOUNS"

I       Pron * @(PRON I)
                (^PERS)=1
                (^NUM)=sg
                (^CASE)=nom.

you     Pron * @(PRON you)
                (^PERS)=2
                {(^NUM)=sg
                 | (^NUM)=pl}.

he      Pron * @(PRON he)
                (^PERS)=3
                (^NUM)=sg
                (^CASE)=nom.

she     Pron * @(PRON she)
                (^PERS)=3
                (^NUM)=sg
                (^CASE)=nom.

it      Pron * @(PRON it)
                (^PERS)=3
                (^NUM)=sg.

we      Pron * @(PRON we)
                (^PERS)=1
                (^NUM)=pl
                 (^CASE)=nom.

they   Pron * @(PRON they)
                (^PERS)=3
                (^NUM)=pl
                (^CASE)=nom.

me     Pron * @(PRON I)
                (^PERS)=1
                (^NUM)=sg
                (^CASE)=acc.

him    Pron * @(PRON he)
                (^PERS)=3
                (^NUM)=sg
                (^CASE)=acc.

her      Pron * @(PRON she)
                (^PERS)=3
                (^NUM)=sg
                (^CASE)=acc.

us      Pron * @(PRON we)
                (^PERS)=1
                (^NUM)=pl
                (^CASE)=acc.

them     Pron * @(PRON they)
                (^PERS)=3
                (^NUM)=pl
                (^CASE)=acc.

my      Pron  * @(POSS I)
                (^PERS)=1
                (^NUM)=sg.

your     Pron  * @(POSS you)
                (^PERS)=2
               {(^NUM)=sg
                 | (^NUM)=pl}.

his      Pron  * @(POSS he)
                (^PERS)=3
                (^NUM)=sg.

her       Pron  * @(POSS she)
                (^PERS)=3
                (^NUM)=sg.

its       Pron  * @(POSS it)
                (^PERS)=3
                (^NUM)=sg.

our       Pron  * @(POSS we)
                (^PERS)=1
                (^NUM)=pl.

their     Pron  * @(POSS they)
                (^PERS)=3
                (^NUM)=pl.






"PREPOSITIONS"

"by	P *  (^PRED)= 'by<( ^OBJ)>'
              {(^ PTYPE)= sem
              @(OT-MARK PPadj)
              |
              (^ PTYPE)= nosem
               (^ PFORM)= by}."

by      P * @(PREP by).

to 	P * @(PREP to).

on 	P * @(PREP on).

in 	P * @(PREP in).

with 	P * @(PREP with).

for     P * @(PREP for).



.  PERIOD * .

,  COMMA * .


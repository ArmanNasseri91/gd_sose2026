DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   S.
  FILES  .
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD PPadj +PPattach.
  GENOPTIMALITYORDER NOGOOD .

----

DEMO   ENGLISH   RULES (1.0)

 
   S --> NP: (^ SUBJ)=!
	      (! CASE)= nom;
 	 VP
         (PERIOD).

   
   VP --> (AUX) 
          V: ^=!;
          (NP: (^ OBJ)=!           "optional direct object"
               (! CASE)=acc)
	  (NP: (^ OBJ2)=!)           "optional indirect object" 
	  PP*: { ! $ (^ ADJUNCT)      "PPs can be adjuncts"
	        (! PTYPE) =c sem      "constraining equation: only semantic PPs here"
                (! OBJ ANIM)=c +
                 @(OT-MARK PPadj)
                 |
                 ! $ (^ ADJUNCT)      
	        (! PTYPE) =c sem      
                (! OBJ ANIM)=c -
                 |
                 (^ OBL) = !       "or a a general oblique"
                @(OT-MARK PPadj) };
	  (PP: (^ OBL-TO) = !
                (! PFORM)=c to)      "oblique beneficiary for ditransitives"         
          (PP: (^ OBL-AG) = !
	        (! PFORM)=c by)      "oblique agent of passive"
   	  AdvP*: ! $ (^ ADJUNCT).    "adverbs modifying verbs"


   PP --> { P: ^ = !            "head of PP"
	   (! PTYPE) =c sem;    "semantic type, Adjunct"
           NP: (^ OBJ) = !
	   (! CASE) = acc;
	   |
	   P: ^ = !             "head of PP"
	   (! PTYPE) =c nosem;   "non-semantic type, OBL"
	   NP
	   }.  

"POSS PRONOUNS DO NOT WORK"
   NP --> {
          ({D                            "can leave out ^=!"
            |
             PRON: ^=!
                   (!PRON-TYPE)=c poss})                       
	  AP*: ! $ (^ ADJUNCT);     "introducing adjectives in sets"
	  N                          "head of NP"
	  PP*: ! $ (^ ADJUNCT)      "PPs modifying NPs"
	       (! PTYPE) =c sem          "have to be semantic"
               @(OT-MARK PPattach);
          |
          PRON : ^=!
                (!PRON-TYPE)=c pers
            }.
 
  AP  --> AdvP*: ! $ (^ ADJUNCT);   "adverbs modifying adjectives"
          (COMMA)
          A.

  AdvP --> Adv*: ! $ (^ ADJUNCT);   "adverbs modifying adverbs"
          (COMMA)
           Adv.

  PRON --> Pron: ^ = !
            {(!PRON-TYPE)=pers
            |
            (!PRON-TYPE)=poss}.


----

DEMO ENGLISH TEMPLATES (1.0)

  OT-MARK(_mark)= 
                    _mark $ o::*.                                       


"Passive lexical rule"
PASS(FRAME) = { FRAME                   "no passive, just give back subcat frame"
	(^ PASSIVE) = -                  "no passive"
	| FRAME                          "passive"
	(^ PASSIVE) = +                  "mark as such"
	(^ PARTICIPLE) =c past            "make sure to have a past participle"
	(^ OBJ)-->(^ SUBJ)               "obj goes to subj; only (at least) transitives"
	{ (^ SUBJ)-->(^ OBL-AG)           "either make subj obl-ag"
	| (^ SUBJ)--> NULL                "or delete"
	}
		}. 



"Dative shift rule"
DAT-SHIFT(FRAME) = { FRAME
			| FRAME
			(^ OBJ)-->(^ OBJ2)
			(^ OBL-TO)-->(^ OBJ)
			}.

"Template for 3sg"
PRES3SG = (^ TENSE) = pres
	  (^ SUBJ PERS) = 3
	  (^ SUBJ NUM) = sg.


"Parameterised template for count nouns"
CN(P) = (^PRED)='P'
	(^ NUM)=sg
	(^ DEF).

"Count plural nouns"
CNPL(P) = (^PRED)='P'
	  (^ NUM)=pl
	  {(^ DEF)}.


INTRANS(P) = (^ PRED)='P<(^ SUBJ)>'.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ) (^ OBJ)>').


OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }. 


DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ)(^ OBL-TO)>')).

"template for put"
LOC(P) = @(PASS (^PRED) = 'P<(^ SUBJ)(^OBJ)(^OBL)>')
         (^OBL PTYPE) = nosem.

"template for prepositions"
PREP(P) =  { (^ PRED) = 'P<(^OBJ)>'
	   (^ PTYPE) = sem
	   | (^ PTYPE) = nosem
	   (^ PFORM) = P}.

"template for advectives"
AP(P) = (^PRED) = 'P'.

"template for adverbs"
Adv(P) = (^PRED) = 'P'.

"template for personal pronouns"
PRON(P) = (^PRED)='P'
          (^PRON-TYPE)=pers.

"template for possessive pronouns"
POSS(P) = (^PRED)='P'
          (^PRON-TYPE)=poss
          (^CASE)= gen.


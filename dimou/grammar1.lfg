DEMO ENGLISH LEXICON (1.0)


is         V *  (^MOOD) = indicative
                @PRES3SG
		@(TRANS be).

be         V *  (^MOOD) = indicative
		@(TRANS be).

was        AUX * (^MOOD) = indicative
                 (^TENSE)= past.


devour    V *  (^ MOOD) = indicative
	       @(TRANS devour).


devours   V *  (^ MOOD) = indicative
               @PRES3SG
	       @(TRANS devour).

devoured  V *  (^MOOD) = indicative
               {(^TENSE)= past |
                (^PARTICIPLE)= past }
		@(TRANS devour).
	       

eat       V *  (^MOOD) = indicative
               @(OPT-TRANS eat).

eats       V *  (^MOOD) = indicative
               @(OPT-TRANS eat)
               @PRES3SG.

ate       V * (^MOOD) = indicative
              (^TENSE)= past
              @(OPT-TRANS eat).


chase 	  V *  (^MOOD) = indicative
               @(TRANS chase).
               
chases     V *  (^MOOD) = indicative
               @(TRANS chase)
                @PRES3SG.

sleep     V *  (^ MOOD) = indicative
               @(INTRANS sleep).

sleeps    V *  (^ MOOD) = indicative
               @PRES3SG
               @(INTRANS sleep).

slept    V * (^MOOD) = indicative
             (^TENSE)= past
             @(INTRANS sleep).

sit      V *  (^ MOOD) = indicative
               @(INTRANS sit).

sits       V *  (^ MOOD) = indicative
               @PRES3SG
               @(INTRANS sit).

sat       V *  (^MOOD) = indicative
               {(^TENSE)= past |
                (^PARTICIPLE)= past }
		@(INTRANS sit).

appear    V *   @(INTRANS appear)
	       (^ MOOD) = indicative.

appears   V *   @(INTRANS appear)
	       (^ MOOD) = indicative
               @PRES3SG.

appeared   V *   @(INTRANS appear)
	       (^ MOOD) = indicative
               (^TENSE) = past.

give      V *  (^MOOD) = indicative
		@(DITRANS give).

gives     V *  (^MOOD) = indicative
		@(DITRANS give)
		@PRES3SG.

gave      V *  (^MOOD) = indicative
                (^TENSE)= past
		@(DITRANS give).

given     V *   (^PARTICIPLE) = past
		@(DITRANS give).

wait       V *  (^MOOD) = indicative
		@(OPT-TRANS wait).
          

waits      V *  (^MOOD) = indicative
		 @(OPT-TRANS wait)
                 @PRES3SG.

waited    V *  (^MOOD) = indicative
               {(^TENSE)= past |
                (^PARTICIPLE)= past}
                @(OPT-TRANS wait).
		
argue     V *  (^MOOD) = indicative
               @(TRANS argue).

argues    V *  (^MOOD) = indicative
               @(TRANS argue)
    	       @PRES3SG.

argued    V * (^MOOD) = indicative
               {(^TENSE)= past |
                (^PARTICIPLE)= past}
		@(TRANS argue).

talk       V *  (^MOOD) = indicative
               @(TRANS talk).

talks      V *  (^MOOD) = indicative
               @(TRANS talk)
    	       @PRES3SG.

talked     V * (^MOOD) = indicative
               {(^TENSE)= past |
                (^PARTICIPLE)= past}
		@(TRANS talk).

see       V *  (^MOOD) = indicative
               @(OPT-TRANS see).

sees      V *  (^MOOD) = indicative
               @(OPT-TRANS sees)
    	       @PRES3SG.

saw        V * (^MOOD) = indicative
               (^TENSE)= past 
		@(OPT-TRANS see).

seen       V * (^PARTICIPLE) = past
		@(OPT-TRANS see).

put        V * @(LOC put)
               {(^TENSE)= present |
                (^PARTICIPLE)= past}
               (^MOOD) = indicative.

puts       V * @(LOC put)
               (^MOOD) = indicative
               @PRES3SG.


"NOUNS"

bones 	  N * (^ PRED) = 'bone'
	      (^ NUM) = pl
	      (^ PERS) = 3. 

bone 	  N * (^PRED) = 'bone'
